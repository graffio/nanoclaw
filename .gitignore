# Dependencies
node_modules/
.npm-cache/
# Build output
dist/

# Local data & auth
store/
data/
logs/

# Groups - only track base structure and specific CLAUDE.md files
groups/*
!groups/main/
!groups/global/
!groups/telegram_main/
groups/main/*
!groups/main/CLAUDE.md
